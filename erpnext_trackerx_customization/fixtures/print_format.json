  "html": "<!-- HTML Template -->\n{% for item_row in doc.items %}\n  {% set item_doc = frappe.get_doc(\"Item\", item_row.item_code) %}\n  <div class=\"label-page\">\n    <div class=\"label-container\">\n      <table class=\"label-table\" cellspacing=\"0\" cellpadding=\"0\">\n        <tbody>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Date: {{ doc.posting_date or \"\" }}</td>\n            <td class=\"cell-left\">PO No: {{ doc.purchase_order or \"\" }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Roll No: {{ item_row.roll_no or \"\" }}</td>\n            <td class=\"cell-left\">Weight: {{ item_row.received_quantity or \"\" }} kg</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-right\">OCN: {{ doc.ocn or \"\" }}</td>\n            <td class=\"cell-left\">Style: {{ item_row.item_code or \"\" }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-right\">Colour: {{ item_row.color or \"\" }}</td>\n            <td class=\"cell-left\">Lot No: {{ item_row.lot_no or \"\" }}</td>\n          </tr>\n          <tr class=\"row-data\">\n            <td class=\"cell-left\">Dia: {{ item_doc.custom_dia or \"\" }}</td>\n            <td class=\"cell-right\">GSM: {{ item_doc.custom_gsm or \"\" }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n{% endfor %}\n\n<!-- CSS Styling -->\n<style>\n/* Thermal Printer Optimized Styling - 203 DPI */\n@page {\n  size: 80mm 50mm;\n  margin: 0;\n  padding: 0;\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 8pt;\n  line-height: 1.1;\n  -webkit-print-color-adjust: exact;\n  print-color-adjust: exact;\n  image-rendering: -webkit-optimize-contrast;\n  image-rendering: crisp-edges;\n}\n\n.label-page {\n  width: 80mm;\n  height: 50mm;\n  max-height: 50mm;\n  page-break-after: always;\n  break-after: page;\n  page-break-inside: avoid;\n  break-inside: avoid;\n  position: relative;\n  overflow: hidden;\n  display: block;\n  box-sizing: border-box;\n}\n\n.label-page:last-child {\n  page-break-after: avoid;\n  break-after: avoid;\n}\n\n.label-container {\n  width: 100%;\n  height: 48mm;\n  padding: 1mm;\n  box-sizing: border-box;\n}\n\n.label-table {\n  width: 100%;\n  height: 46mm;\n  border-collapse: collapse;\n  table-layout: fixed;\n  border: 0.5pt solid #000;\n}\n\n/* Row Heights */\n.row-header {\n  height: 8mm;\n}\n\n.row-data {\n  height: 7mm;\n}\n\n/* Cell Styling - Wrap without breaking words */\n.label-table td {\n  padding: 0.5mm 1mm;\n  vertical-align: middle !important;\n  border: 0.5pt solid #000;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 8pt;\n  font-weight: normal;\n  color: #000;\n  overflow: visible !important;\n  text-overflow: ellipsis !important;\n  white-space: normal !important;\n  word-wrap: break-word !important;\n  word-break: normal !important;\n  overflow-wrap: break-word !important;\n  text-rendering: geometricPrecision;\n  -webkit-font-smoothing: none;\n  -moz-osx-font-smoothing: grayscale;\n  display: table-cell !important;\n  max-width: 0 !important;\n}\n\n/* Column Widths */\n.cell-left {\n  width: 50%;\n  text-align: left;\n}\n\n.cell-right {\n  width: 50%;\n  text-align: left;\n}\n\n/* Header Styling */\n.sbu-header {\n  text-align: center;\n  font-weight: bold;\n  font-family: 'Arial', 'Helvetica', sans-serif;\n  font-size: 10pt;\n  text-transform: uppercase;\n  color: #000;\n  white-space: normal !important;\n  word-wrap: break-word !important;\n  word-break: normal !important;\n  overflow-wrap: break-word !important;\n}\n\n/* Print-specific adjustments for thermal printer */\n@media print {\n  @page {\n    size: 80mm 50mm;\n    margin: 0 !important;\n    padding: 0 !important;\n  }\n  \n  html, body {\n    width: 80mm !important;\n    height: 50mm !important;\n    margin: 0 !important;\n    padding: 0 !important;\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n  }\n  \n  .label-page {\n    width: 80mm !important;\n    height: 50mm !important;\n    max-height: 50mm !important;\n    page-break-after: always !important;\n    break-after: page !important;\n  }\n  \n  .label-page:last-child {\n    page-break-after: avoid !important;\n    break-after: avoid !important;\n  }\n  \n  .label-container {\n    padding: 1mm !important;\n  }\n  \n  .label-table {\n    border: 0.5pt solid #000 !important;\n    border-collapse: collapse !important;\n  }\n  \n  .label-table td {\n    border: 0.5pt solid #000 !important;\n    font-family: 'Arial', 'Helvetica', sans-serif !important;\n    font-size: 8pt !important;\n    padding: 0.5mm 1mm !important;\n    color: #000 !important;\n    -webkit-print-color-adjust: exact !important;\n    print-color-adjust: exact !important;\n    text-rendering: geometricPrecision !important;\n    -webkit-font-smoothing: none !important;\n    overflow: visible !important;\n    white-space: normal !important;\n    word-wrap: break-word !important;\n    word-break: normal !important;\n    overflow-wrap: break-word !important;\n  }\n  \n  .sbu-header {\n    font-size: 10pt !important;\n    font-weight: bold !important;\n    font-family: 'Arial', 'Helvetica', sans-serif !important;\n    white-space: normal !important;\n    word-wrap: break-word !important;\n    word-break: normal !important;\n    overflow-wrap: break-word !important;\n  }\n  \n  .row-header {\n    height: 8mm !important;\n  }\n  \n  .row-data {\n    height: 7mm !important;\n  }\n}\n</style>",
