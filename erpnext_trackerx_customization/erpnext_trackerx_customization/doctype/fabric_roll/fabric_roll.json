{
 "doctype": "DocType",
 "name": "Fabric Roll",
 "module": "Erpnext Trackerx Customization",
 "custom": 1,
 "is_submittable": 0,
 "autoname": "FR-.YYYY.-.#####",
 "fields": [
  {
    "fieldname": "roll_id",
    "label": "Roll ID (Serial No.)",
    "fieldtype": "Data",
    "read_only": 1,
    "reqd": 1,
    "default": "New"
  },
  {
    "fieldname": "item_code",
    "label": "Item Code",
    "fieldtype": "Link",
    "options": "Item",
    "reqd": 1
  },
  {
    "fieldname": "supplier",
    "label": "Supplier",
    "fieldtype": "Link",
    "options": "Supplier"
  },
  {
    "fieldname": "width",
    "label": "Width (inches)",
    "fieldtype": "Float"
  },
  {
    "fieldname": "length",
    "label": "Length (meters)",
    "fieldtype": "Float"
  },
  {"fieldname": "shade_code", "fieldtype": "Link", "options": "Shade Code", "label": "Shade Code"},
  {
    "fieldname": "lot_no",
    "label": "Lot No.",
    "fieldtype": "Data"
  },
  {
    "fieldname": "gsm",
    "label": "GSM",
    "fieldtype": "Float"
  },
  {
    "fieldname": "inspection_status",
    "label": "Inspection Status",
    "fieldtype": "Select",
    "options": "\nPending\nIn Progress\nPassed\nRejected\nPartial"
  },
  {
    "fieldname": "linked_purchase_receipt",
    "label": "Linked Purchase Receipt",
    "fieldtype": "Link",
    "options": "Purchase Receipt"
  },
  {
    "fieldname": "current_warehouse",
    "label": "Current Warehouse",
    "fieldtype": "Link",
    "options": "Warehouse"
  },
  {
    "fieldname": "is_allocated",
    "label": "Is Allocated",
    "fieldtype": "Check"
  },
  {
    "fieldname": "grn",
    "label": "Goods Receipt Note",
    "fieldtype": "Link",
    "options": "Goods Receipt Note"
  },
  {
    "fieldname": "mir",
    "label": "Material Inspection Report",
    "fieldtype": "Link",
    "options": "Material Inspection Report"
  },
  {
    "fieldname": "inspection_section",
    "label": "Inspection Details",
    "fieldtype": "Section Break",
    "collapsible": 1,
    "depends_on": "eval:doc.inspection_status != 'Pending'"
  },
  {
    "fieldname": "inspection_method",
    "label": "Inspection Method",
    "fieldtype": "Select",
    "options": "\nFull Roll\n4-Point Method\nRandom Sampling\n10-Point Method",
    "default": "4-Point Method"
  },
  {
    "fieldname": "inspected_length",
    "label": "Inspected Length (m)",
    "fieldtype": "Float",
    "precision": 2
  },
  {
    "fieldname": "column_break_insp",
    "fieldtype": "Column Break"
  },
  {
    "fieldname": "inspector_name",
    "label": "Inspector Name",
    "fieldtype": "Data"
  },
  {
    "fieldname": "inspection_date",
    "label": "Inspection Date",
    "fieldtype": "Date"
  },
  {
    "fieldname": "defects_section",
    "label": "Defects Found",
    "fieldtype": "Section Break"
  },
  {
    "fieldname": "defects",
    "label": "Defects",
    "fieldtype": "Table",
    "options": "Fabric Defect Item",
    "depends_on": "eval:doc.inspection_status != 'Pending'"
  },
  {
    "fieldname": "calculation_section",
    "label": "Calculation & Results",
    "fieldtype": "Section Break",
    "depends_on": "eval:doc.defects && doc.defects.length > 0"
  },
  {
    "fieldname": "total_defect_points",
    "label": "Total Defect Points",
    "fieldtype": "Float",
    "precision": 2,
    "read_only": 1
  },
  {
    "fieldname": "points_per_100_sqm",
    "label": "Points per 100 sqm",
    "fieldtype": "Float",
    "precision": 2,
    "read_only": 1
  },
  {
    "fieldname": "column_break_calc",
    "fieldtype": "Column Break"
  },
  {
    "fieldname": "fabric_grade",
    "label": "Fabric Grade",
    "fieldtype": "Data",
    "read_only": 1
  },
  {
    "fieldname": "final_result",
    "label": "Final Result",
    "fieldtype": "Select",
    "options": "\nFirst Quality\nSecond Quality\nRejected",
    "read_only": 1
  },
  {
    "fieldname": "inspection_remarks",
    "label": "Inspection Remarks",
    "fieldtype": "Text"
  }
 ],
 "permissions": [
  {
   "role": "Stock Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  }
 ]
}
